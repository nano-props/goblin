{
  "name": "goblin",
  "productName": "Goblin",
  "version": "0.2.0",
  "description": "Goblin — Git Branch List",
  "private": true,
  "type": "module",
  "main": "src/main/main.ts",
  "imports": {
    "#/*": "./src/*",
    "#scripts/*": "./scripts/*"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "start": "bun run build:web && electron .",
    "build": "bun scripts/build.ts",
    "build:preload": "bun scripts/build-preload.ts",
    "build:web": "vite build",
    "build:server": "bun build ./src/server/entrypoints/main.ts ./src/server/entrypoints/pty-worker.ts ./src/server/entrypoints/g-command.ts --outdir ./dist/server --target node --external node-pty",
    "start:server": "node scripts/start-server.ts",
    "build:electron": "electron-builder",
    "install:app": "bun install.ts",
    "check:boundaries": "bun scripts/check-boundaries.ts",
    "check:no-html-injection": "bun scripts/check-no-html-injection.ts",
    "check": "bun run check:boundaries && bun run check:no-html-injection",
    "typecheck": "bun scripts/typecheck.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "bun scripts/publish.ts",
    "count-lines": "bun scripts/count-lines.ts",
    "clean": "rm -rf dist release"
  },
  "devDependencies": {
    "@babel/parser": "7.28.5",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@tanstack/react-router-devtools": "1.167.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "4.0.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@hono/node-server": "2.0.8",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-virtual": "3.14.5",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-image": "0.9.0",
    "@xterm/addon-progress": "0.2.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/headless": "6.0.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "consola": "3.4.2",
    "croner": "10.0.1",
    "date-fns": "4.4.0",
    "es-toolkit": "1.49.0",
    "execa": "9.6.1",
    "hono": "4.12.28",
    "i18next": "26.3.6",
    "immer": "11.1.11",
    "lru-cache": "11.5.2",
    "lucide-react": "1.24.0",
    "nanoid": "5.1.16",
    "node-pty": "1.1.0",
    "p-limit": "7.3.0",
    "p-queue": "9.3.1",
    "pino": "10.3.1",
    "qrcode": "1.5.4",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.9",
    "react-resizable-panels": "4.12.1",
    "smol-toml": "1.7.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tinyglobby": "0.2.17",
    "valibot": "1.4.2",
    "write-file-atomic": "8.0.0",
    "ws": "8.21.0",
    "zustand": "5.0.14"
  }
}
