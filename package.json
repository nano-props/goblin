{
  "name": "goblin",
  "version": "0.1.0",
  "description": "Goblin — Git Branch List, desktop edition",
  "private": true,
  "type": "module",
  "main": "src/main/main.ts",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green 'vite build --watch --mode development' 'electron .'",
    "start": "vite build && electron .",
    "build": "bun scripts/build.ts",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "bun scripts/publish.ts",
    "count-lines": "bun scripts/count-lines.ts",
    "clean": "rm -rf dist release"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/write-file-atomic": "4.0.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "9.2.1",
    "electron": "42.2.0",
    "electron-builder": "26.8.1",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@trpc/client": "11.17.0",
    "@trpc/server": "11.17.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-image": "0.9.0",
    "@xterm/addon-progress": "0.2.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.3.0",
    "execa": "9.6.1",
    "i18next": "26.2.0",
    "immer": "11.1.8",
    "lru-cache": "11.5.0",
    "lucide-react": "1.16.0",
    "node-pty": "1.1.0",
    "p-limit": "7.3.0",
    "p-queue": "9.3.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-error-boundary": "6.1.1",
    "react-i18next": "17.0.8",
    "react-resizable-panels": "4.11.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "valibot": "1.4.0",
    "write-file-atomic": "8.0.0",
    "zustand": "5.0.13"
  }
}
