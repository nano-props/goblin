{
  "name": "goblin",
  "version": "0.1.0",
  "description": "Goblin — Git Branch List, desktop edition",
  "private": true,
  "type": "module",
  "main": "src/main/main.ts",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green 'vite build --watch --mode development' 'electron .'",
    "start": "vite build && electron .",
    "build": "bun scripts/build.ts",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "bun scripts/publish.ts",
    "count-lines": "bun scripts/count-lines.ts",
    "clean": "rm -rf dist release"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "9.2.1",
    "electron": "42.1.0",
    "electron-builder": "26.8.1",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.2.1",
    "i18next": "26.2.0",
    "lucide-react": "1.16.0",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.8",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zustand": "5.0.13"
  }
}
